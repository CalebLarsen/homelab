name: anki

services:
  anki:
    image: "{{ item.image }}"
    container_name: anki
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ="{{ timezone }}"
      - SYNC_USER1={{ anki_secret.sync_user1 }}
      - SYNC_USER2={{ anki_secret.sync_user2 }}
    volumes:
      - "{{ config_root }}/anki:/anki_data"
{% set use_vpn = item.use_vpn | default(false) %}
{% set host_port = item.port %}
{% set internal_port = item.internal_port | default(8080) %}
{% include "_service_network.yml.j2" %}
    restart: unless-stopped

{% include "_network_footer.yml.j2" %}
