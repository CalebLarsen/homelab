name: caddy

services:
  caddy:
    image: "{{ item.image }}"
    container_name: caddy
    restart: unless-stopped
    ports:
      - 80:80
      - 443:443
    volumes:
      - "{{ config_root }}/caddy/Caddyfile:/etc/caddy/Caddyfile"
      - "{{ config_root }}/caddy/data:/data"
      - "{{ config_root }}/caddy/config:/config"
      - "{{ storage.site_root }}:/var/www/html:ro"
    networks:
      - "{{ docker_network }}"

networks:
  "{{ docker_network }}":
    external: true
