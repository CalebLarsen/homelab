#!/usr/bin/env bash
# Nightly restic backup of {{ config_root }} -> {{ backup.target }}.
# Generated by Ansible (roles/backup) — direct edits will be overwritten.
# See docs/backups.md for restore instructions.
set -euo pipefail

export RESTIC_REPOSITORY="{{ backup.target }}"
export RESTIC_PASSWORD="{{ restic_password }}"

ts() { date -u +%Y-%m-%dT%H:%M:%SZ; }
log() { echo "[$(ts)] $*"; }

log "starting backup"

# Take consistent SQLite snapshots first. A live .db file has -wal/-shm
# sidecars; copying just the .db during a write produces a torn snapshot.
# `sqlite3 .backup` is an online, transactionally consistent copy that
# does not block the writer.
SQLITE_STAGING="/var/lib/homelab-backup/sqlite-staging"
mkdir -p "$SQLITE_STAGING"
chmod 0700 "$SQLITE_STAGING"

snapshot_sqlite() {
  local src="$1"
  local name
  name="$(basename "$src")"
  if [[ -f "$src" ]]; then
    log "snapshotting $src"
    sqlite3 "$src" ".backup '$SQLITE_STAGING/$name'" || log "WARN: snapshot of $src failed (continuing)"
  fi
}

# Servarr DBs are small, hot, and contain irreplaceable history (request
# logs, indexer config, custom formats). Plex's `com.plexapp.plugins.library.db`
# is large and Plex tolerates a torn copy at restore time, so we don't
# stage it — restic's exclude rules below will skip the WAL sidecars.
snapshot_sqlite "{{ config_root }}/sonarr/sonarr.db"
snapshot_sqlite "{{ config_root }}/radarr/radarr.db"
snapshot_sqlite "{{ config_root }}/prowlarr/prowlarr.db"
snapshot_sqlite "{{ config_root }}/bazarr/db/bazarr.db"
snapshot_sqlite "{{ config_root }}/cleanuparr/cleanuparr.db"
snapshot_sqlite "{{ config_root }}/cleanuparr/users.db"

log "running restic backup"
restic backup \
  --tag homelab-config \
  --exclude='*.db-shm' \
  --exclude='*.db-wal' \
  --exclude='*.tmp' \
  --exclude='**/Cache/**' \
  --exclude='**/cache/**' \
  --exclude='**/Logs/**' \
  --exclude='**/MediaCover/**' \
  --exclude='**/MediaCovers/**' \
  --exclude='**/Plex Media Server/Cache/**' \
  --exclude='**/Plex Media Server/Logs/**' \
  --exclude='**/Plex Media Server/Crash Reports/**' \
  --exclude='**/Plex Media Server/Codecs/**' \
  "{{ config_root }}" \
  "$SQLITE_STAGING"

log "applying retention policy"
restic forget \
  --tag homelab-config \
  --keep-daily 7 \
  --keep-weekly 4 \
  --keep-monthly 6 \
  --prune

# Clean up staging — restic has the data now.
rm -rf "$SQLITE_STAGING"

log "backup complete"

# Self-test: verify the most recent snapshot is readable. Cheap sanity
# check that catches password rotation mistakes and disk failures.
log "running integrity check"
restic check --read-data-subset=1% || log "WARN: restic check reported issues"

log "done"
