libraries:
  Movies:
    remove_overlays: false
    operations:
      label:
{% for user in overseerr_secret.users if user.label is defined %}
        - name: {{ user.label }}
          radarr_tag: {{ user.label }}
{% endfor %}
  TV Shows:
    remove_overlays: false
    operations:
      label:
{% for user in overseerr_secret.users if user.label is defined %}
        - name: {{ user.label }}
          sonarr_tag: {{ user.label }}
{% endfor %}

settings:
  run_order:
  - operations
  cache: true
  cache_expiration: 60
  asset_directory: config/assets
  asset_folders: true
  asset_depth: 0
  create_asset_folders: false
  prioritize_assets: false
  dimensional_asset_serialization: false
  download_url_assets: false
  show_missing_season_assets: false
  show_missing_episode_assets: false
  show_asset_not_needed: true
  sync_mode: append
  minimum_items: 1
  default_collection_order: release
  delete_below_minimum: false
  delete_not_scheduled: false
  run_again_delay: 2
  missing_only_released: false
  only_filter_missing: false
  show_unmanaged: true
  show_filtered: false
  show_options: false
  show_missing: true
  show_missing_assets: true
  save_report: false
  report_path: config/reports
  clean_report: true
  tvdb_language: en
  ignore_ids:
  ignore_imdb_ids:
  item_refresh_delay: 0
  multi_library_threads: 1
  multi_collection_threads: 1
  verify_ssl: true
  custom_repo:
  check_nightly: false

tmdb:
  apikey: {{ tmdb_api_key | default('REPLACE_ME') }}

plex:
  url: http://172.17.0.1:32400
  token: {{ plex_secret.online_token }}
  timeout: 60
  clean_bundles: false
  empty_trash: false
  optimize: false

radarr:
  url: http://radarr:7878
  token: {{ api_keys.radarr }}
  quality_profile: Any
  add_missing: false
  add_existing: false
  upgrade_existing: false
  monitor: true
  availability: announced
  root_folder_path: /data/media/movies
  search: false
  tag:
  ignore_cache: false

sonarr:
  url: http://sonarr:8989
  token: {{ api_keys.sonarr }}
  quality_profile: Any
  language_profile: English
  add_missing: false
  add_existing: false
  upgrade_existing: false
  monitor: all
  user_status:
  root_folder_path: /data/media/tv
  search: false
  tag:
  ignore_cache: false
