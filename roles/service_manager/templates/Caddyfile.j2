{
    auto_https off
}

http://{{ cloudflare.domain }} {
    log {
        output file /var/log/caddy/apex.log {
            roll_size 100MiB
            roll_keep 10
        }
        format json
    }
    root * /var/www/html
    file_server
}

# Static site checked out by roles/notes; no backend container, so it is not
# driven by the services list and is hard-coded here.
http://note.{{ cloudflare.domain }} {
    log {
        output file /var/log/caddy/note.log {
            roll_size 100MiB
            roll_keep 10
        }
        format json
    }
    root * /var/www/html/note
    file_server
}

http:// {
{% for service in services if service.public | default(false) %}
    {% if service.subdomain != "@" %}
    log {{ service.name }} {
        hostnames {{ service.subdomain }}.{{ cloudflare.domain }}
        output file /var/log/caddy/{{ service.name }}.log {
            roll_size 100MiB
            roll_keep 10
        }
        format json
    }
    {% endif %}
{% endfor %}

{% for service in services if service.public | default(false) %}
    {% if service.subdomain != "@" %}
    @{{ service.name }} host {{ service.subdomain }}.{{ cloudflare.domain }}
    handle @{{ service.name }} {
        reverse_proxy {{ service.name }}:{{ service.internal_port | default(service.port) }}
    }
    {% endif %}
{% endfor %}

    # Fallback for unmapped subdomains
    handle {
        abort
    }
}
